# ------------------------------------------------------------------
# Variaveis de ambiente - Frontend do Dimensionador FullEnergy
#
# Copie este arquivo para ".env" e ajuste se necessario.
# ------------------------------------------------------------------

# URL base da API FastAPI (backend). Em desenvolvimento local, o backend
# roda em http://127.0.0.1:8000 (ver backend/README).
VITE_API_BASE_URL=http://127.0.0.1:8000

# Supabase - usado apenas para persistencia de Projetos Salvos.
# Usar SOMENTE a anon key publica. NUNCA a service_role key no frontend.
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=coloque_aqui_a_anon_key
