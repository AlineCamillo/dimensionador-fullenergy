# ------------------------------------------------------------------
# Variaveis de ambiente - Dimensionador de Baterias LiFePO4 (FullEnergy)
#
# Copie este arquivo para ".env" e ajuste os valores conforme necessario.
# Nesta etapa (backend de calculo + API), a aplicacao AINDA NAO LE estas
# variaveis automaticamente (nao ha carregador de configuracao implementado);
# elas estao aqui para padronizar a configuracao das proximas etapas
# (banco de dados, autenticacao, deploy).
# ------------------------------------------------------------------

# Ambiente da aplicacao (development | production)
ENVIRONMENT=development

# Host e porta usados ao executar o uvicorn
API_HOST=0.0.0.0
API_PORT=8000

# Origens permitidas para CORS (separadas por virgula). Em desenvolvimento,
# o backend libera "*" diretamente em app/main.py.
CORS_ORIGINS=*

# ---------------- Variaveis futuras (ainda nao utilizadas) ----------------

# Banco de dados (etapa de persistencia)
# DATABASE_URL=sqlite:///./dimensionador.db

# Autenticacao / usuarios (etapa de login e perfis)
# SECRET_KEY=changeme
# ACCESS_TOKEN_EXPIRE_MINUTES=60
