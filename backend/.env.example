# Copie este arquivo para .env e preencha com os valores do seu projeto Supabase.
# O arquivo .env NAO deve ser versionado (ja esta no .gitignore).

# URL do projeto Supabase (Settings > API > Project URL)
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave service_role (Settings > API > Project API Keys > service_role)
# ATENCAO: esta chave bypassa o RLS. Nunca expor ao frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
